# ─────────────────────────────────────────
# Wireless HeatMapper — Variables de entorno de referencia
# Copiar a .env y completar con valores reales (nunca commitear .env)
# ─────────────────────────────────────────

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=heatmapper
POSTGRES_USER=heatmapper_user
POSTGRES_PASSWORD=cambia_esto_en_produccion

# Bindings de desarrollo (por defecto solo localhost de la máquina/VM)
NGINX_BIND_HOST=127.0.0.1
NGINX_HOST_PORT=80
BACKEND_BIND_HOST=127.0.0.1
BACKEND_HOST_PORT=8000

# Backend FastAPI
DATABASE_URL=postgresql://heatmapper_user:cambia_esto_en_produccion@db:5432/heatmapper
SECRET_KEY=cambia_esto_por_un_secreto_seguro_de_al_menos_32_caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Web React (Vite)
VITE_API_BASE_URL=http://localhost/api
